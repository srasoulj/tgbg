#############################################
# Desktop sync app – sample environment file
#############################################

# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash_here

# Local session file name; will be created next to the app
TELEGRAM_SESSION_NAME=telegram_sync_session

#############################################
# Database (MySQL)
#############################################

# Host / port of your MySQL server
DB_HOST=localhost
DB_PORT=3306

# Database name and credentials
DB_NAME=telegram_reader
DB_USER=tgbg
DB_PASSWORD=your_db_password_here

# Path to CA file if you connect over SSL/TLS (leave empty for local non-SSL)
DB_SSL_CA=

